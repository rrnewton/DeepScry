# Markdown backend temporary files
*.tmp.*
*.lock.*
*.trash.*

# SQLite database files (local runtime, not source of truth)
beads.db
beads.db-shm
beads.db-wal

# Local beads metadata (generated by bd init)
.local_version
metadata.json
README.md

# Daemon runtime files
daemon.log
daemon.pid
daemon.*
bd.sock
bd.sock.startlock
bd.sock.*

# Keep markdown issues (source of truth for git)
# !markdown.db/issues/*.md
!markdown.db/*

minibeads.lock
command_history.log
