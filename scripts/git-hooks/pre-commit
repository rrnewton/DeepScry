#!/usr/bin/env bash
# Pre-commit hook: guard beads frontmatter, then check Rust formatting.
#
# CI's `fmt` job (.github/workflows/ci.yml) runs `cargo fmt --all -- --check`
# against the nightly toolchain and a single mis-formatted line will fail the
# build. CI's validate `lint.beads-dupkey` step rejects duplicate top-level YAML
# keys in .beads/issues/*.md (a 3-way merge of two `mb update`s of the same
# tracker leaves a dup `updated_at:` that breaks `mb list`/`mb show`). This hook
# is a lightweight local guard so we catch both classes of drift before pushing.
#
# Install with: make install-hooks
#
# To bypass for an emergency commit (e.g. mid-rebase WIP), use --no-verify.

set -euo pipefail

# --- beads frontmatter dup-key guard -------------------------------------
# Runs whenever a .beads/issues/*.md file is staged (independent of the Rust
# fmt check below, so a beads-only commit is still guarded). Checks only the
# STAGED files; a duplicate top-level key is a hard failure.
mapfile -t staged_beads < <(git diff --cached --name-only --diff-filter=ACMR \
    | grep -E '^\.beads/issues/.*\.md$' || true)
if [ "${#staged_beads[@]}" -gt 0 ] && command -v python3 >/dev/null 2>&1; then
    if ! python3 scripts/check_beads_dup_keys.py "${staged_beads[@]}"; then
        cat >&2 <<'EOF'

✗ pre-commit: duplicate top-level YAML key in a staged beads issue file.

  Fix with:   make beads-check REPAIR=1     (keeps the latest updated_at)
  Re-stage:   git add .beads/issues
  Commit again.

  CI's validate lint.beads-dupkey step will reject this otherwise. To bypass
  for an emergency commit, re-run with --no-verify.
EOF
        exit 1
    fi
fi

# Only run the Rust fmt check when there are staged Rust files; this keeps the
# hook out of the way for purely-docs / beads-only commits or merge commits.
if ! git diff --cached --name-only --diff-filter=ACMR | grep -qE '\.rs$'; then
    exit 0
fi

if ! command -v cargo >/dev/null 2>&1; then
    echo "pre-commit: cargo not on PATH; skipping fmt check" >&2
    exit 0
fi

# Prefer nightly to match CI exactly, fall back to default toolchain.
if rustup toolchain list 2>/dev/null | grep -q '^nightly'; then
    fmt_cmd=(cargo +nightly fmt --all -- --check)
else
    fmt_cmd=(cargo fmt --all -- --check)
fi

if ! "${fmt_cmd[@]}"; then
    cat >&2 <<'EOF'

✗ pre-commit: Rust formatting check failed.

  Fix with:   make fmt        (or: cargo fmt --all)
  Re-stage:   git add -u
  Commit again.

  CI's `fmt` job will reject this commit otherwise. To bypass for an
  emergency commit, re-run with --no-verify.
EOF
    exit 1
fi
