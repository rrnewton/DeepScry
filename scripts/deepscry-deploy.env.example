# deepscry-deploy.env — local, non-version-controlled deploy config.
#
# Copy this file to:
#     <parent>/.deepscry-deploy.env       (the dev harness root; preferred)
# or:
#     <repo>/.deepscry-deploy.env         (the mtg-forge-rs primary checkout)
# or:
#     ~/.config/deepscry/deploy.env
#
# Then edit the values below. The deploy script (`scripts/deploy.sh`)
# searches those three locations in order and sources the first one it
# finds. CLI flags / environment variables override values from the
# file.
#
# ABSOLUTELY NOTHING in this file is checked into the repository —
# `.deepscry-deploy.env` is in .gitignore. This file
# (`deepscry-deploy.env.example`) IS tracked as a template.

# --- Required ---------------------------------------------------------

# SSH login name on the remote VM.
REMOTE_USER=your-username

# Public hostname for the deployed site (used in the generated
# server-config.js so the landing page knows where the WebSocket
# endpoint lives — typically your DNS name, possibly proxied through
# Cloudflare).
REMOTE_HOST=example.com

# --- Optional ---------------------------------------------------------

# SSH target host. Defaults to ${REMOTE_HOST}. Override when the public
# DNS name is fronted by a CDN/proxy and SSH must go to the VM's real
# IP directly.
# REMOTE_SSH_HOST=203.0.113.42

# Remote install directory under $HOME on the VM.
# REMOTE_DIR=mtg-forge-rs

# HTTP port the unified axum server listens on. Default 8080 (works
# under both systemd-system and systemd-user modes).
# REMOTE_PORT=8080

# TLS termination directly on the VM (rustls). Leave unset for plain
# HTTP — typical when a CDN (Cloudflare) terminates TLS and forwards
# plaintext to the origin port.
# TLS_CERT_PATH=/etc/ssl/deepscry/deepscry.crt
# TLS_KEY_PATH=/etc/ssl/deepscry/deepscry.key

# systemd unit name (also used as the basename for the env file under
# /etc/default/<name> in system mode, or ~/.config/systemd/user/<name>.service
# in user mode).
# SERVICE_NAME=deepscry

# systemd mode: "user" (default — no root needed for deploy phase,
# enables lingering so service runs even when REMOTE_USER not logged
# in) or "system" (config phase needs root, deploy phase needs
# passwordless sudo for `systemctl restart <name>`). Privileged ports
# (<1024) require system mode.
# SYSTEMD_MODE=user

# --- Bug reports ------------------------------------------------------

# Optional password that marks submitted bug reports as "trusted".
# When set, playtesters who know this secret can send bug reports that
# trigger automated GitHub issue filing and Claude autofix. When unset
# (or empty), ALL reports are stored as untrusted — bug reports still
# work, but no automation runs. The deploy script warns (and proceeds)
# when this is not set.
#
# IMPORTANT: Keep this value out of version control. This file IS tracked
# as a template — the actual value goes in your LOCAL .deepscry-deploy.env
# (which is gitignored).
#
# TRUSTED_BUG_REPORT_PASSWORD=your-secret-here
