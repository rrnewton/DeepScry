bad_fonts_mtg_tui.png
node_modules/
package-lock.json
*.png
*.jpg
*.jpeg
*.gif
*.webp
# QA / Playwright screenshot captures are NEVER committed (see CLAUDE.md
# "NEVER commit images"). Belt-and-suspenders dir ignore on top of *.png.
web/screenshots/

# Web E2E test result JSON artifacts (written to web/ root by the network
# e2e tests, e.g. network_test_results.json / network_random_test_results.json).
# Transient run output, never tracked.
web/*_test_results.json

# Debug directory for one-off scripts and temporary files
# See CLAUDE.md section "Debugging Scripts and Temporary Files"
debug/

# Downloaded card images (large, local-only)
# Downloaded by `mtg download` command
images/

# Coverage (cargo-llvm-cov)
*.profraw
*.profdata
lcov.info
experiment_results/coverage/

# Legacy one-off scripts (should be moved to debug/)
# Keeping these patterns temporarily for backward compatibility
check_*.js
debug_*.js
inspect_*.js
measure_*.js
sanity_test_*.js
test_*.js
# ...but the web/ E2E + deploy-tree tests ARE core test scripts wired into
# `make validate` (and GitHub CI) — keep them tracked despite the broad
# `test_*.js` ignore above (mtg-682).
!web/test_*.js
simple_screenshot.js
quick_screenshot.js
dom_inspection_test.js
serve_no_cache.py
console_logs.txt
sanity_test_console.txt
output.dck
# dhat-heap covered by **/dhat-heap*.json above

# Local, non-version-controlled deploy config (scripts/deploy-cloud.sh).
# See scripts/deepscry-deploy.env.example for the template.
.deepscry-deploy.env
